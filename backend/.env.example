PORT=4000

# Pick any string. You enter the same value in Meta's webhook setup screen.
META_VERIFY_TOKEN=change_me

# Page token with leads_retrieval, used to read the full lead from the Graph API.
PAGE_ACCESS_TOKEN=

# Only needed if VERIFY_SIGNATURE is on.
META_APP_SECRET=
VERIFY_SIGNATURE=false

GRAPH_API_VERSION=v21.0
